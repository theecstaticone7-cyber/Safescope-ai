# ── Node.js ──────────────────────────────────────────────────────────────────
# These are downloaded by `npm install` and can be massive (400+ MB).
# Anyone who clones the repo just runs `npm install` to get them back.
node_modules/
npm-debug.log*

# ── Python ───────────────────────────────────────────────────────────────────
# Python compiles .py files into faster bytecode — these are auto-generated.
__pycache__/
*.pyc
*.pyo

# Virtual environments (Python's equivalent of node_modules)
.venv/
venv/
env/

# ── Environment / Secret files ───────────────────────────────────────────────
# .env contains your real MongoDB password and API keys — NEVER commit this.
# .env.example (the template without real values) IS committed — that's safe.
.env
.env.local
.env.*.local

# ── Data files (large / proprietary) ─────────────────────────────────────────
# NCRB Excel files and processed CSV — too large for Git, not open-source.
*.xlsx
*.xls
*.csv

# Raw and processed data folders
data/raw/
data/processed/

# ── ML model files ────────────────────────────────────────────────────────────
# Trained model binaries — large and reproducible by running train_model.py.
*.pkl
*.joblib
*.h5
models/vector_store/

# ── Frontend build output ─────────────────────────────────────────────────────
# Generated by `npm run build` — not source code.
frontend/build/
frontend/dist/
frontend/.env.local

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ── OS junk ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Claude Code internal folder ───────────────────────────────────────────────
# Contains AI session memory — not project source code.
.claude/
